{
  "name": "task-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "json-server --watch db.json --port 3000",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vue-tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "axios": "^1.7.9",
    "vue-draggable-plus": "^0.6.0",
    "chart.js": "^4.4.7",
    "vue-chartjs": "^5.3.2",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.11",
    "vue-tsc": "^2.2.0",
    "sass": "^1.83.4",
    "json-server": "^0.17.4",
    "concurrently": "^9.1.2"
  }
